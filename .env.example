# Local Development
# Production-only integrations are disabled here so contributors can run the
# frontend against a local backend without Stripe or other prod credentials.
NEXT_PUBLIC_API_URL=http://localhost:8083/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000
NEXT_IMAGE_REMOTE_SOURCES=http://localhost:9000

# E2E test seed credentials
E2E_EXISTING_EMAIL=olivia@example.com
E2E_EXISTING_PASSWORD=p@ss1logic11

# Stripe Hosted Checkout UI toggle.
# Keep disabled for normal localhost runs. Set to true only when your local
# backend has STRIPE_ENABLED=true and valid Stripe test-mode keys.
# Use Stripe test cards only: https://docs.stripe.com/testing#cards
NEXT_PUBLIC_STRIPE_ENABLED=false

# Google OAuth sign-in. Requires a valid Google Client ID on the backend.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# AI-powered review summaries. Requires the backend AI service to be configured.
NEXT_PUBLIC_AI_ENABLED=false

# Email confirmation flow (registration code, password reset).
# Keep disabled when the backend has EMAIL_ENABLED=false.
NEXT_PUBLIC_EMAIL_CONFIRMATION_ENABLED=false
