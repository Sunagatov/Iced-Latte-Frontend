{
  "name": "iced-latte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tsc": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "lsof -ti :3000 | xargs kill -9 2>/dev/null; PORT=3000 next dev & sleep 6 && playwright test --project=mocked; kill %1 2>/dev/null",
    "test:e2e:report": "playwright show-report",
    "test:e2e:local-real": "lsof -ti :3000 | xargs kill -9 2>/dev/null; PORT=3000 next dev & sleep 6 && BASE_URL=http://localhost:3000 playwright test --project=real; kill %1 2>/dev/null",
    "test:e2e:prod-smoke": "BASE_URL=https://iced-latte.uk playwright test --project=prod-smoke"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10",
    "axios": "1.15.0",
    "axios-cache-interceptor": "^1.11.4",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6",
    "next": "16.2.3",
    "postcss": "^8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-toastify": "^11.0.5",
    "sharp": "^0.34.5",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "yup": "^1.7.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/eslint-plugin-next": "^15.3.4",
    "@playwright/test": "^1.58.2",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-testing-library": "^7.16.0",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-sonar": "^0.2.16",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-calendar": "^6.0.0",
    "stripe": "^20.4.1",
    "supports-color": "^10.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "usehooks-ts": "^3.1.1"
  }
}
